# Maintainer: taotieren <admin@taotieren.com>

pkgname=python-spsdk-pylint-plugins
_name=${pkgname#python-}
pkgver=0.2.4
pkgrel=1
pkgdesc="PyLint plugins coverity SPSDK-specific coding rules."
arch=(any)
url="https://pypi.org/project/${_name}"
license=(BSD-3-Clause)
depends=(
  python
  python-astroid
  python-pylint
)
makedepends=(
  python-build
  python-installer
  python-setuptools
  python-wheel
)
checkdepends=()
optdepends=()
groups=(spsdk-plugins)
provides=(${_name})
conflicts=(${_name})
replaces=(${_name})
_name=${_name//-/_}
source=("${_name}-${pkgver}.tar.gz::https://files.pythonhosted.org/packages/source/${_name::1}/${_name//_/-}/$_name-$pkgver.tar.gz")
sha512sums=('df295ddd1f0e1f2191d5cd17a96f09f373ccbf49aadb723ac4cd771cd2a74c6d76ddd0d06558ca2ea8d666d9359fde3e71dde9d928fbf75061004e5664e0a4e2')

build() {
  cd ${srcdir}/$_name-$pkgver
  python -m build --wheel --no-isolation
}

package() {
  cd ${srcdir}/$_name-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE -t ${pkgdir}/usr/share/licenses/${pkgname}/
}
