# Maintainer: taotieren <admin@taotieren.com>

pkgname=ts.net-git
pkgver=r636.092ce57
pkgrel=1
epoch=
pkgdesc="Thunderscope-compatible PC-host software written in C# using high-performing primitives & SIMD."
arch=($CARCH)
url="https://github.com/EEVengers/TS.NET"
license=('MIT')
provides=(${pkgname%-git})
conflicts=(${pkgname%-git})
replaces=()
depends=(
    sh
    glibc
    libgcc
    libstdc++
    # AUR
    libtslitex
)
makedepends=(
    curl
    git
    dotnet-host
    dotnet-runtime
    dotnet-sdk
)
optdepends=()
backup=()
options=('!strip' '!debug' '!lto')
source=("${pkgname}::git+${url}.git")
sha256sums=('SKIP')
noextract=()

pkgver() {
    cd "${srcdir}/${pkgname}"
    (
        set -o pipefail
        git describe --long --tag --abbrev=7 2>/dev/null | sed 's/^v//g;s/\([^-]*-g\)/r\1/;s/-/./g' ||
            printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
    )
}

prepare() {
    git -C "${srcdir}/${pkgname}" clean -dfx
}

build() {
    cd "${srcdir}/${pkgname}/build-scripts"
    ./TS.NET.Engine.cs -p:PublishTrimmed=false
    # if [ "$CARCH" == "aarch64" ]; then
    #     msg2 "build for arm64"
    #     dotnet publish source/TS.NET.Engine -r linux-arm64 -c Release -p:-p:SysRoot=/crossrootfs/arm64 -p:PublishTrimmed=true --self-contained true -p:DebugType=None -p:DebugSymbols=false -o artifact
    # else
    #     msg2 "build for x64"
    #     dotnet publish source/TS.NET.Engine -r linux-x64 -c Release -p:PublishTrimmed=true --self-contained true -p:DebugType=None -p:DebugSymbols=false -o artifact
    # fi
    # cd artifact/
    # ./TS.NET.Engine
}

package() {
    cd "${srcdir}/${pkgname}/"
    if [ "$CARCH" == "aarch64" ]; then
        msg2 "install for arm64"
        cd build/TS.NET.Engine/linux-arm64
        install -vDm755 TS.NET.Engine -t ${pkgdir}/usr/share/${pkgname}/
        install -vDm644 thunderscope* -t ${pkgdir}/usr/share/${pkgname}/
    else
        msg2 "install for x64"
        cd build/TS.NET.Engine/linux-x64
        install -vDm755 TS.NET.Engine -t ${pkgdir}/usr/share/${pkgname}/
        install -vDm644 thunderscope* -t ${pkgdir}/usr/share/${pkgname}/
    fi
    
    install -vDm755 /dev/stdin ${pkgdir}/usr/bin/${pkgname%-git} <<EOF
#!/bin/env bash
cd /usr/share/${pkgname}/
./TS.NET.Engine "\$@"
EOF
    cd "${srcdir}/${pkgname}/"
    install -vDm644 LICENSE ${pkgdir}/usr/share/licenses/${pkgname}/LICENSE
    install -vDm644 README.md ${pkgdir}/usr/share/doc/${pkgname}/README.md
    install -vDm644 docs/*.md -t ${pkgdir}/usr/share/doc/${pkgname}/docs/
    install -vDm644 docs/*.drawio -t ${pkgdir}/usr/share/doc/${pkgname}/docs/
    install -vDm644 docs/simulations/*.asc -t ${pkgdir}/usr/share/doc/${pkgname}/docs/simulations/
}
