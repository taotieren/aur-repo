# Maintainer: taotieren <admin@taotieren.com>

pkgname=python-unidic-lite
_pkgname=${pkgname#python-}
pkgver=1.0.8
pkgrel=2
pkgdesc="A small version of UniDic packaged for Python"
arch=('any')
url="https://github.com/polm/unidic-lite"
license=('MIT AND BSD-3-Clause')
conflicts=("${pkgname}")
provides=("${pkgname}")
depends=(
    python

)
makedepends=(
    python-build
    python-installer
    python-setuptools 
    python-wheel 
)
source=("${_pkgname}-${pkgver}.tar.gz::https://files.pythonhosted.org/packages/source/${_name::1}/$_name/$_name-$pkgver.tar.gz")
sha256sums=('db9d4572d9fdd4d00a97949d4b0741ec480ee05a7e7e2e32f547500dae27b245')

build() {
    cd "${srcdir}/${_pkgname}-${pkgver}"

    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/${_pkgname}-${pkgver}"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE* -t "$pkgdir/usr/share/licenses/$pkgname/"
}
